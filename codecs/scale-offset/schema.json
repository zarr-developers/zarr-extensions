{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "const": "scale-offset"
    },
    "configuration": {
      "type": "object",
      "properties": {
        "offset": {
          "type": "number"
        },
        "scale": {
          "type": "number"
        },
        "astype": {
          "type": ["string", "object"]
        }
      },
      "required": ["offset", "scale"],
      "additionalProperties": false
    }
  },
  "required": ["name", "configuration"],
  "additionalProperties": false
}
