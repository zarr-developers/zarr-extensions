{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "const": "bytes"
        },
        "configuration": {
          "type": "object",
          "properties": {
            "endian": {
              "type": "string",
              "enum": ["little", "big"]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false,
      "required": ["name"]
    },
    {
      "type": "string",
      "const": "bytes"
    }
  ]
}
