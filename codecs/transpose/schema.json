{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "const": "transpose"
    },
    "configuration": {
      "type": "object",
      "properties": {
        "order": {
          "type": "array",
          "items": {
            "type": "integer",
            "range": {
              "min": 0
            }
          },
          "uniqueItems": true
        }
      },
      "required": [
        "order"
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}