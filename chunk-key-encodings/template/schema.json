{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "const": "generic"
    },
    "configuration": {
      "type": "object",
      "properties": {
        "format": {
          "type": "string",
          "pattern": "\\{((\\*|-?\\d+)(:0(\\d+))?)\\}"
        },
        "separator": {
          "type": "string"
        }
      },
      "required": [
        "format"
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}